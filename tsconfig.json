{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@contracts/*": ["contracts/*"],
      "@core/*": ["core/*"],
      "@skills/*": ["skills/*"],
      "@capabilities/*": ["capabilities/*"],
      "@registry/*": ["registry/*"],
      "@governance/*": ["governance/*"],
      "@extensions/*": ["extensions/*"],
      "@evaluation/*": ["evaluation/*"]
    }
  },
  "include": ["contracts", "core", "skills", "capabilities", "registry", "governance", "extensions", "evaluation", "examples", "tests"],
  "exclude": ["node_modules", "dist"]
}
