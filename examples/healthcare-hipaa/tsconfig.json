{
  "compilerOptions": {
    "target": "ES2020", "module": "ES2020", "lib": ["ES2020"],
    "declaration": true, "outDir": "./dist", "strict": true,
    "esModuleInterop": true, "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true, "resolveJsonModule": true,
    "moduleResolution": "node", "baseUrl": "../../",
    "paths": {
      "@contracts/*": ["contracts/*"], "@core/*": ["core/*"],
      "@governance/*": ["governance/*"], "@skills/*": ["skills/*"],
      "@capabilities/*": ["capabilities/*"], "@registry/*": ["registry/*"],
      "@extensions/*": ["extensions/*"], "@evaluation/*": ["evaluation/*"]
    }
  },
  "include": ["src/**/*"], "exclude": ["node_modules"]
}
